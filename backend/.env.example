# Server
NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eagle_foundry?schema=public

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_COOKIE_NAME=ef_refresh_token
REFRESH_COOKIE_DOMAIN=
REFRESH_COOKIE_SAME_SITE=lax
REFRESH_COOKIE_SECURE=true  # Must be true in production; set to false only for local HTTP dev/testing
UPLOAD_TOKEN_SECRET=your-upload-token-secret-min-32-chars

# Email Domain Rules
STUDENT_EMAIL_DOMAIN=ashland.edu
BLOCKED_EMAIL_DOMAINS=gmail.com,yahoo.com,outlook.com,hotmail.com,icloud.com,proton.me,aol.com,mail.com

# OTP Configuration
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_SEND_LIMIT_PER_HOUR=5
OTP_HASH_PEPPER=your-otp-pepper-secret-min-32-chars

# MFA Configuration
MFA_ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
MFA_CHALLENGE_TTL_MINUTES=5
MFA_MAX_ATTEMPTS=5
MFA_ISSUER=Eagle-Foundry
MFA_BACKUP_CODES_COUNT=10
MFA_BACKUP_CODE_PEPPER=your-mfa-backup-code-pepper-min-32-chars

# Field encryption + messaging E2EE
AWS_KMS_KEY_ID=arn:aws:kms:us-east-1:123456789:key/replace-with-real-key-id
FIELD_ENCRYPTION_HASH_PEPPER=your-field-encryption-hash-pepper-min-32-chars
E2EE_REQUIRED=false
E2EE_ALLOW_LEGACY_THREADS=true

# Login lockout
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=30

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=eagle-foundry-files
SES_FROM_EMAIL=noreply@eaglefoundry.ashland.edu
SQS_EVENTS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/eagle-foundry-events

# Sentry (optional)
SENTRY_DSN=
